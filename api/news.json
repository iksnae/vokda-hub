---
---
{
  "generated": "{{ site.time | date_to_xmlschema }}",
  "count": {{ site.posts | size }},
  "items": [{% for post in site.posts limit:20 %}
    {
      "title": {{ post.title | jsonify }},
      "date": "{{ post.date | date: '%Y-%m-%d' }}",
      "slug": "{{ post.slug }}",
      "url": {{ post.url | prepend: site.url | jsonify }},
      "summary": {{ post.summary | default: "" | jsonify }},
      "tags": {{ post.tags | jsonify }},
      "providerId": {{ post.providerId | default: null | jsonify }}
    }{% unless forloop.last %},{% endunless %}{% endfor %}
  ]
}
